{
  "name": "wedding-invitation-slideshow",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "dev:emulator": "cd server && npm run serve",
    "dev": "concurrently \"npm run dev:emulator\" \"npm run dev:client\"",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "build": "npm run build:client && npm run build:server",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:all": "npm run build:client && cd server && npm run deploy && cd .. && firebase deploy --only firestore:rules",
    "emulators": "firebase emulators:start",
    "install:all": "npm install && cd client && npm install && cd ../server && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "main": "index.js",
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "firebase": "^12.11.0",
    "nvm": "^0.0.4",
    "vite": "^8.0.1"
  }
}
