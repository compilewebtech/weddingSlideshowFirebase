# Email (Gmail App Password - create at myaccount.google.com/apppasswords)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Local dev only: use in-memory OTP to bypass Firestore (avoids PERMISSION_DENIED)
# USE_IN_MEMORY_OTP=true

# CORS - comma-separated list of allowed client origins (no trailing slashes)
CLIENT_URL=https://weddingslideshowf.netlify.app,https://weddingslideshow.netlify.app

NODE_ENV=production

# Production: set in Firebase Console > Functions > Environment variables
