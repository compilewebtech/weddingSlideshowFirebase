# Firebase Client Config (from Firebase Console > Project Settings)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# API URL (required for RSVP - OTP verification)
# Local: http://localhost:5001/wedding-invitation-slideshow/us-central1/api
# Production:
VITE_API_URL=https://us-central1-wedding-invitation-slideshow.cloudfunctions.net/api

# Optional: Secret for invite link encryption (default: wedding-invite-2024)
# VITE_INVITE_SECRET=your-secret-key
